# FoodWorld environment configuration template
# Copy this file to .env for local development, then replace every placeholder.
# Never commit .env or any file containing real credentials.

APP_ENV=development
SECRET_KEY=replace-with-a-long-random-secret

# Use DATABASE_URL, or provide the component variables below.
DATABASE_URL=mysql+pymysql://database_user:database_password@localhost:3306/foodworld
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=foodworld
# DB_USER=database_user
# DB_PASSWORD=database_password

# Optional integrations. The application shows a fallback when these are absent.
GEMINI_API_KEY=replace-with-your-gemini-api-key
PEXELS_API_KEY=replace-with-your-pexels-api-key

# Optional port used by local development.
PORT=3000
